{
  "name": "@nexigrate/ai-pipeline",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "Cross-model AI verification layer. Wraps a primary generator with a second-model fact-checker; flags low-confidence outputs for regeneration. Backs the marketing 'verified by 3-layer AI detection' claim.",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": ["dist"],
  "scripts": {
    "build": "tsc -p tsconfig.build.json",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "tsc --noEmit",
    "clean": "rm -rf .turbo dist"
  },
  "dependencies": {
    "@nexigrate/shared": "workspace:*"
  },
  "devDependencies": {
    "typescript": "^5.7.3",
    "vitest": "^2.1.8"
  }
}
