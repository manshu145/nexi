# Sample environment variables for the Nexigrate API.
# Copy to .env and edit. Never commit your real .env.

# Standard Node env. 'development' enables stub auth; 'production' requires Firebase.
NODE_ENV=development

# Port the HTTP server listens on. Cloud Run overrides this at runtime.
PORT=8080

# 'stub' (default in dev): accept tokens of the form `stub:<userId>[:<role>]`.
# 'firebase': verify real Firebase ID tokens via firebase-admin.
AUTH_MODE=stub

# GCP project pinned to production (the only environment we have right now).
# When AUTH_MODE=firebase, GCP_PROJECT_ID must equal the Firebase Auth project
# the client signed in against.
GCP_PROJECT_ID=nexigrate-prod
GCP_PROJECT_NUMBER=505978726927
GCP_REGION=asia-south1
GCP_SERVICE_ACCOUNT=nexigrate-api@nexigrate-prod.iam.gserviceaccount.com

# Firestore + Storage emulators (uncomment when running the local emulator suite)
# FIRESTORE_EMULATOR_HOST=localhost:8080
# FIREBASE_AUTH_EMULATOR_HOST=localhost:9099
# FIREBASE_STORAGE_EMULATOR_HOST=localhost:9199

# Comma-separated list of allowed CORS origins for the browser apps.
CORS_ALLOWED_ORIGINS=http://localhost:3000,http://localhost:4321

# Set to 'true' in Cloud Run so logs land in Cloud Logging as JSON.
LOG_JSON=false

# ----- Razorpay (Phase 2.8) -----
# Test mode keys. The KEY_ID is the publishable half and is safe in code/env;
# KEY_SECRET MUST come from a GitHub Secret / Cloud Run secret -- never commit it.
RAZORPAY_KEY_ID=rzp_test_SsPfzbJUMaK7Ow
# RAZORPAY_KEY_SECRET=  # set via secrets manager only
# RAZORPAY_WEBHOOK_SECRET=  # set via secrets manager only

# ----- AI providers (Phase 2.9) -----
# All real API keys live in GitHub Secrets and are injected at deploy time.
# OPENAI_API_KEY=
# GEMINI_API_KEY=
# GROQ_API_KEY=

# ----- Email (Phase 2.5+) -----
# RESEND_API_KEY=
RESEND_FROM_EMAIL=hello@nexigrate.com
