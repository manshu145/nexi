# Sample environment variables for the Nexigrate API.
# Copy to .env and edit. Never commit your real .env.

# Standard Node env. 'development' enables stub auth; 'production' requires Firebase.
NODE_ENV=development

# Port the HTTP server listens on. Cloud Run overrides this at runtime.
PORT=8080

# 'stub' (default in dev): accept tokens of the form `stub:<userId>[:<role>]`.
# 'firebase': verify real Firebase ID tokens via firebase-admin.
AUTH_MODE=stub

# GCP project id. Required when AUTH_MODE=firebase. Unused with stub auth.
# GCP_PROJECT_ID=nexigrate-prod

# Comma-separated list of allowed CORS origins for the browser apps.
CORS_ALLOWED_ORIGINS=http://localhost:3000,http://localhost:4321

# Set to 'true' in Cloud Run so logs land in Cloud Logging as JSON.
LOG_JSON=false
