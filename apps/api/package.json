{
  "name": "@nexigrate/api",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "Nexigrate backend API. Hono on Node 22, deployed to Cloud Run (asia-south1).",
  "main": "./src/server.ts",
  "scripts": {
    "dev": "tsx watch src/server.ts",
    "build": "tsc -p tsconfig.build.json",
    "start": "node dist/server.js",
    "typecheck": "tsc --noEmit",
    "lint": "tsc --noEmit",
    "test": "vitest run --passWithNoTests",
    "test:watch": "vitest",
    "clean": "rm -rf dist .turbo",
    "bootstrap-admin": "node scripts/bootstrap-admin.mjs"
  },
  "dependencies": {
    "@google/genai": "^2.9.0",
    "@hono/node-server": "^1.13.7",
    "@nexigrate/ai-pipeline": "workspace:*",
    "@nexigrate/credits": "workspace:*",
    "@nexigrate/shared": "workspace:*",
    "firebase-admin": "^13.0.2",
    "groq-sdk": "^1.2.0",
    "hono": "^4.6.16",
    "openai": "^6.39.0",
    "zod": "^3.24.1"
  },
  "devDependencies": {
    "@types/node": "^22.10.5",
    "tsx": "^4.19.2",
    "typescript": "^5.7.3",
    "vitest": "^2.1.8"
  }
}
