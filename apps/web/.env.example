# Public Firebase Web SDK config -- safe to commit / bake into the bundle.
# These values are also imported from infra/firebase/web-config.ts; this file
# exists for tools that read .env directly (e.g. running Next dev server with
# a different project).
NEXT_PUBLIC_FIREBASE_API_KEY=AIzaSyBQuLPo3N9PMWov9sUrp7czVzBix4lPj8M
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=nexigrate-prod.firebaseapp.com
NEXT_PUBLIC_FIREBASE_PROJECT_ID=nexigrate-prod
NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET=nexigrate-prod.firebasestorage.app
NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=505978726927
NEXT_PUBLIC_FIREBASE_APP_ID=1:505978726927:web:066fb77f927442d1e3117a

# Where the api lives. In production, this is api.nexigrate.com once Cloud
# Run is deployed and the custom domain is mapped.
NEXT_PUBLIC_API_BASE_URL=http://localhost:9090
