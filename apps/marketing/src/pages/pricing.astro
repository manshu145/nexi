---
import Layout from '~/layouts/Layout.astro';
import Nav from '~/components/Nav.astro';
import Footer from '~/components/Footer.astro';

export const prerender = false; // PR-43: SSR — fetch live prices from API

const APP_UPGRADE_URL = 'https://app.nexigrate.com/upgrade';
const API_URL = 'https://api.nexigrate.com';

// Fetch live plan data from the backend. Falls back to hardcoded defaults
// if the API is unreachable (Cloudflare edge timeout, etc).
interface LivePlan { id: string; name: string; price: number; yearlyPrice: number; isActive: boolean; comingSoon: boolean; }
let livePlans: LivePlan[] = [];
try {
  const res = await fetch(`${API_URL}/v1/branding`);
  if (res.ok) {
    const data = (await res.json()) as { plans?: LivePlan[] };
    if (data.plans?.length) livePlans = data.plans;
  }
} catch { /* fall through to hardcoded defaults */ }

interface PlanConfig {
  slug: 'scholar' | 'aspirant' | 'achiever';
  label: string;
  description: string;
  monthlyInr: number;
  yearlyInr: number;
}

const plans: PlanConfig[] = [
  {
    slug: 'scholar',
    label: livePlans.find(p => p.id === 'scholar')?.name ?? 'Starter',
    description: 'Ad-free, AI tutor, 8 chapters/day, 6 AI images/day. Great to begin.',
    monthlyInr: livePlans.find(p => p.id === 'scholar')?.price ?? 79,
    yearlyInr: livePlans.find(p => p.id === 'scholar')?.yearlyPrice ?? 599,
  },
  {
    slug: 'aspirant',
    label: livePlans.find(p => p.id === 'aspirant')?.name ?? 'Pro',
    description: 'More of everything + essay grading. For serious aspirants.',
    monthlyInr: livePlans.find(p => p.id === 'aspirant')?.price ?? 249,
    yearlyInr: livePlans.find(p => p.id === 'aspirant')?.yearlyPrice ?? 1899,
  },
  {
    slug: 'achiever',
    label: livePlans.find(p => p.id === 'achiever')?.name ?? 'Elite',
    description: 'Unlimited study + priority AI + mentor support. Go all-in.',
    monthlyInr: livePlans.find(p => p.id === 'achiever')?.price ?? 599,
    yearlyInr: livePlans.find(p => p.id === 'achiever')?.yearlyPrice ?? 4499,
  },
];

interface FeatureRow {
  label: string;
  notes?: string;
  values: { scholar: string; aspirant: string; achiever: string };
}

const featureRows: FeatureRow[] = [
  {
    label: 'Daily MCQ',
    values: { scholar: '30 / day', aspirant: '100 / day', achiever: 'Unlimited' },
  },
  {
    label: 'Chapters per day',
    values: { scholar: '8', aspirant: '25', achiever: 'Unlimited' },
  },
  {
    label: 'Mock tests',
    values: { scholar: '5 / mo', aspirant: '15 / mo', achiever: '40 / mo' },
  },
  {
    label: 'AI tutor (Q&A)',
    values: { scholar: '30 / day', aspirant: '100 / day', achiever: '300 / day' },
  },
  {
    label: 'Essay & answer grading',
    values: { scholar: '3 / day', aspirant: '10 / day', achiever: 'Unlimited' },
  },
  {
    label: 'AI image generation',
    values: { scholar: '6 / day', aspirant: '15 / day', achiever: '50 / day' },
  },
  {
    label: 'Daily current affairs + quiz',
    values: { scholar: '✓', aspirant: '✓', achiever: '✓' },
  },
  {
    label: 'Priority AI (GPT-4o)',
    values: { scholar: '—', aspirant: '✓', achiever: '✓' },
  },
  {
    label: 'Mentor support',
    values: { scholar: '—', aspirant: '—', achiever: '✓' },
  },
  {
    label: 'Credit deduction',
    values: { scholar: 'None', aspirant: 'None', achiever: 'None' },
  },
  {
    label: 'Ad-free, no distractions',
    values: { scholar: '✓', aspirant: '✓', achiever: '✓' },
  },
  {
    label: 'Cancel any time',
    notes: 'No auto-renewal. No refunds on completed payments — see policy below.',
    values: { scholar: '✓', aspirant: '✓', achiever: '✓' },
  },
];
---

<Layout
  title="Pricing — Nexigrate"
  description="Plans built for Indian students. Free forever for the daily MCQ. Upgrade for mock tests, AI tutoring, and current affairs."
  pathname="/pricing"
>
  <Nav />
  <main id="main" class="mx-auto max-w-5xl px-5 py-16 sm:py-20">
    <div class="max-w-2xl">
      <p class="pill mb-5">Pricing</p>
      <h1 class="font-serif text-4xl font-semibold leading-tight text-ink-900 sm:text-5xl">
        Plans built for Indian students
      </h1>
      <p class="mt-4 text-lg leading-relaxed text-ink-800">
        The daily MCQ is free forever. Upgrade when you want unlimited
        attempts, mock tests, and an AI tutor that doesn't waste your time.
        Pay in ₹ via Razorpay. No auto-renewal — and no refunds on completed
        payments, so choose the period that suits you.
      </p>
    </div>

    <section class="mt-12 grid gap-4 sm:grid-cols-3">
      {plans.map((plan) => (
        <article class={`paper-card flex flex-col p-6 relative ${plan.slug === 'scholar' ? 'border-ember-500 ring-1 ring-ember-500/20' : ''}`}>
          {plan.slug === 'scholar' && (
            <span class="absolute -top-2.5 left-1/2 -translate-x-1/2 px-3 py-0.5 rounded-full text-[10px] font-bold uppercase tracking-wider bg-ember-500 text-paper-50">
              Most Popular
            </span>
          )}
          <h2 class="font-serif text-xl font-semibold text-ink-900">{plan.label}</h2>
          <p class="mt-2 text-sm text-ink-800">{plan.description}</p>
          <p class="font-serif mt-5 text-3xl font-semibold tabular-nums text-ink-900">
            ₹{plan.monthlyInr}
            <span class="ml-1 text-sm font-normal text-muted-500">/mo</span>
          </p>
          <p class="mt-1 text-xs text-muted-500">
            or ₹{plan.yearlyInr}/yr · save ~{Math.round(
              ((plan.monthlyInr * 12 - plan.yearlyInr) / (plan.monthlyInr * 12)) * 100,
            )}%
          </p>
          <a href={APP_UPGRADE_URL} class="btn-primary mt-6 w-full" rel="noopener">
            Choose {plan.label}
          </a>
        </article>
      ))}
    </section>

    <p class="mt-6 text-sm text-muted-500">
      Beta pricing while we onboard the first 1,000 students. Locked in for
      the lifetime of your subscription.
    </p>

    <section class="mt-16">
      <h2 class="font-serif text-2xl font-semibold text-ink-900">What you get on each plan</h2>
      <div class="paper-card mt-5 overflow-x-auto">
        <table class="w-full text-left text-sm">
          <thead>
            <tr class="border-b border-line text-xs font-semibold uppercase tracking-[0.18em] text-muted-500">
              <th class="px-4 py-3">Feature</th>
              <th class="px-4 py-3">Scholar</th>
              <th class="px-4 py-3">Aspirant</th>
              <th class="px-4 py-3">Achiever</th>
            </tr>
          </thead>
          <tbody>
            {featureRows.map((row) => (
              <tr class="border-b border-line last:border-0">
                <td class="px-4 py-3 font-medium text-ink-900">
                  {row.label}
                  {row.notes ? (
                    <span class="block text-xs font-normal text-muted-500">{row.notes}</span>
                  ) : null}
                </td>
                <td class="px-4 py-3 text-ink-800">{row.values.scholar}</td>
                <td class="px-4 py-3 text-ink-800">{row.values.aspirant}</td>
                <td class="px-4 py-3 text-ink-800">{row.values.achiever}</td>
              </tr>
            ))}
          </tbody>
        </table>
      </div>
    </section>

    <section class="mt-14 grid gap-6 sm:grid-cols-2">
      <div class="paper-card p-6">
        <h3 class="font-serif text-lg font-semibold text-ink-900">Free forever</h3>
        <p class="mt-2 text-sm text-ink-800">
          The daily 10-question MCQ for your target exam stays free. Earn
          credits each day. No card on file, no ads, no nags to upgrade.
        </p>
      </div>
      <div class="paper-card p-6">
        <h3 class="font-serif text-lg font-semibold text-ink-900">No refunds, but no surprises</h3>
        <p class="mt-2 text-sm text-ink-800">
          Once a payment is completed we don't issue refunds. In return we
          never auto-renew, never email you a renewal nudge, and the price
          you sign up at is locked in. Read the full
          <a class="text-ember-600 underline" href="/refund">cancellation
          policy</a>.
        </p>
      </div>
      <div class="paper-card p-6">
        <h3 class="font-serif text-lg font-semibold text-ink-900">Cancel any time</h3>
        <p class="mt-2 text-sm text-ink-800">
          One click in your profile cancels the next charge. You keep full
          access until the end of the period you've already paid for, then
          drop to the Free plan automatically. Resume any time before then
          and your plan picks up where it left off.
        </p>
      </div>
      <div class="paper-card p-6">
        <h3 class="font-serif text-lg font-semibold text-ink-900">Indian payments, INR billing</h3>
        <p class="mt-2 text-sm text-ink-800">
          Pay with UPI, cards, netbanking, or wallets via
          <a class="text-ember-600 underline" href="https://razorpay.com" rel="noopener">Razorpay</a>.
          GST invoices on request to <a class="text-ember-600 underline" href="mailto:hello@nexigrate.com">hello@nexigrate.com</a>.
        </p>
      </div>
    </section>

    <div class="mt-14 flex flex-col items-start gap-4 sm:flex-row sm:items-center sm:justify-between">
      <p class="text-sm text-muted-500">
        Questions about a plan? <a class="text-ember-600 underline" href="mailto:hello@nexigrate.com">hello@nexigrate.com</a>
      </p>
      <a href={APP_UPGRADE_URL} class="btn-primary" rel="noopener">
        Sign in and choose a plan
      </a>
    </div>
  </main>
  <Footer />
</Layout>
