---
const sources = [
  { label: 'NCERT',          note: 'Class 6\u201312 textbooks' },
  { label: 'UPSC',           note: 'previous-year papers, official syllabus' },
  { label: 'CBSE',           note: 'sample papers, marking schemes' },
  { label: 'JEE / NEET',     note: 'NTA released papers' },
  { label: 'PIB',            note: 'press releases for current affairs' },
  { label: 'Ministries',     note: 'official Government of India publications' },
] as const;

const verifiers = [
  { name: 'OpenAI',  note: 'GPT-4o-mini \u2014 generation' },
  { name: 'Google',  note: 'Gemini 2.5 Flash \u2014 verifier 1' },
  { name: 'Groq',    note: 'Llama 3.3 70B \u2014 verifier 2' },
  { name: 'Human SME', note: 'final review on flagged content' },
] as const;
---

<section id="trust" class="section border-y border-line bg-paper-50/60">
  <div class="mx-auto max-w-6xl px-5 py-20 sm:py-24">
    <div class="grid gap-12 lg:grid-cols-12">
      <div class="lg:col-span-5">
        <p class="pill mb-5">Trust</p>
        <h2 class="font-serif text-3xl font-semibold leading-tight text-ink-900 sm:text-4xl">
          Sourced from the real thing.
        </h2>
        <p class="mt-4 text-lg leading-relaxed text-ink-800">
          We don't paraphrase someone else's notes. Every chapter, every MCQ,
          every current-affairs item is generated from a primary source you can
          click and read yourself.
        </p>
        <p class="mt-3 text-ink-800">
          Then it is verified three ways before it reaches you.
        </p>
      </div>

      <div class="grid gap-6 lg:col-span-7 lg:grid-cols-2">
        <div class="paper-card p-6">
          <h3 class="font-serif text-lg font-semibold text-ink-900">Primary sources</h3>
          <ul class="mt-4 space-y-2.5">
            {sources.map((s) => (
              <li class="flex items-baseline gap-3">
                <span class="mt-1 inline-block h-1.5 w-1.5 shrink-0 rounded-full bg-ember-600"></span>
                <span class="text-sm text-ink-800">
                  <span class="font-medium">{s.label}</span>
                  <span class="text-muted-500"> \u2014 {s.note}</span>
                </span>
              </li>
            ))}
          </ul>
        </div>

        <div class="paper-card p-6">
          <h3 class="font-serif text-lg font-semibold text-ink-900">Verification pipeline</h3>
          <ol class="mt-4 space-y-2.5">
            {verifiers.map((v, i) => (
              <li class="flex items-baseline gap-3">
                <span class="font-serif text-xs font-semibold tracking-widest text-ember-600">
                  {String(i + 1).padStart(2, '0')}
                </span>
                <span class="text-sm text-ink-800">
                  <span class="font-medium">{v.name}</span>
                  <span class="text-muted-500"> \u2014 {v.note}</span>
                </span>
              </li>
            ))}
          </ol>
        </div>
      </div>
    </div>
  </div>
</section>
