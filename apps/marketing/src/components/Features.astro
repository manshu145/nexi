      From UPSC to JEE — AI-powered, personalized content for Indian competitive exam students.
    </p>

    <div class="mt-12 grid gap-6 sm:grid-cols-2 lg:grid-cols-3">
      {features.map((f) => (
        <div
          class={`group paper-card p-6 relative ${f.status === 'coming-soon' ? 'opacity-60' : 'transition-transform hover:-translate-y-1'}`}
        >
          {f.status === 'coming-soon' && (
            <span class="absolute top-3 right-3 px-2 py-0.5 rounded-full bg-paper-300 text-[10px] font-semibold text-muted-500 uppercase tracking-wider">
              Coming Soon
            </span>
          )}
          <span class="text-2xl">{f.icon}</span>
          <h3 class="mt-3 font-serif text-lg font-semibold text-ink-900 group-hover:text-ember-600 transition-colors">
            {f.title}
          </h3>
          <p class="mt-2 text-sm text-muted-500 leading-relaxed">
            {f.description}
          </p>
        </div>
      ))}
