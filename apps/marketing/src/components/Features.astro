<section id="features" class="py-20 bg-paper-50/50 reveal-on-scroll">
  <div class="mx-auto max-w-6xl px-5">
    <p class="text-center text-xs font-semibold uppercase tracking-[0.2em] text-ember-600">
      Everything you need
    </p>
    <h2 class="mt-3 text-center font-serif text-3xl font-semibold text-ink-900 sm:text-4xl">
      One platform. Every exam.
    </h2>
