---
const earn = [
  { label: 'Verified signup',          value: '+100', note: 'one-time, on phone verify' },
  { label: 'Daily login',              value: '+5',   note: 'every day' },
  { label: 'Complete a chapter',       value: '+20',  note: 'finish reading + quiz' },
  { label: 'Pass daily MCQ (70%+)',    value: '+10',  note: 'core loop' },
  { label: 'Failed MCQ attempt',       value: '+5',   note: 'no one gets locked out' },
  { label: '7-day streak bonus',       value: '+5',   note: 'rewards consistency' },
  { label: '30-day streak bonus',      value: '+10',  note: 'rewards persistence' },
  { label: 'Refer a friend (you)',     value: '+50',  note: 'on their signup' },
  { label: 'Welcome bonus (friend)',   value: '+100', note: 'extra credits for joining via referral' },
] as const;

const spend = [
  { label: 'Read a chapter',          value: '−5'  },
  { label: '1-hour focus session',    value: '−10' },
  { label: 'Mock test',               value: '−20' },
  { label: 'Question to AI tutor',    value: '−2'  },
  { label: 'Concept video',           value: '−5'  },
  { label: 'Long-answer grading',     value: '−30' },
] as const;
---

<section id="credits" class="section reveal-on-scroll">
  <div class="mx-auto max-w-6xl px-5 py-20 sm:py-24">
    <div class="max-w-2xl">
      <p class="pill mb-5">Credits</p>
      <h2 class="font-serif text-3xl font-semibold leading-tight text-ink-900 sm:text-4xl">
        Pay with effort. Or pay with money. Never with attention.
      </h2>
      <p class="mt-4 text-lg leading-relaxed text-ink-800">
        A serious daily student earns more credits than they spend. That is the
        whole point. Subscriptions exist for those who would rather pay than
        take the daily MCQ — they don't unlock anything credits can't.
      </p>
    </div>

    <div class="mt-14 grid gap-6 lg:grid-cols-2">
      <div class="paper-card p-7">
        <h3 class="font-serif text-2xl font-semibold text-ink-900">Earn</h3>
        <ul class="mt-5 divide-y divide-line">
          {earn.map((row) => (
            <li class="flex items-baseline justify-between gap-4 py-3">
              <span class="text-ink-800">
                {row.label}
                <span class="ml-2 text-xs text-muted-500">· {row.note}</span>
              </span>
              <span class="font-serif text-lg font-semibold text-ember-600 tabular-nums">
                {row.value}
              </span>
            </li>
          ))}
        </ul>
      </div>

      <div class="paper-card p-7">
        <h3 class="font-serif text-2xl font-semibold text-ink-900">Spend</h3>
        <ul class="mt-5 divide-y divide-line">
          {spend.map((row) => (
            <li class="flex items-baseline justify-between gap-4 py-3">
              <span class="text-ink-800">{row.label}</span>
              <span class="font-serif text-lg font-semibold text-ink-900 tabular-nums">
                {row.value}
              </span>
            </li>
          ))}
        </ul>

        <div class="mt-7 rounded-lg border border-dashed border-line bg-paper-200 p-4">
          <p class="text-xs font-semibold uppercase tracking-[0.18em] text-muted-500">
            Optional subscriptions
          </p>
          <ul class="mt-2 space-y-1 text-sm text-ink-800">
            <li><span class="font-medium">Starter</span> — ₹79/mo · ad-free study, AI tutor & mock tests</li>
            <li><span class="font-medium">Pro</span> — ₹249/mo · more of everything + essay grading</li>
            <li><span class="font-medium">Elite</span> — ₹599/mo · unlimited study + priority AI + mentor support</li>
          </ul>
          <p class="mt-2 text-xs text-muted-500">Annual plans save ~30% vs monthly.</p>
        </div>

        <p class="mt-4 text-xs text-muted-500">
          Default earn and spend rates shown here. Final amounts may be tuned —
          your in-app <a href="https://app.nexigrate.com/credits" class="underline">Credits</a> page always shows the live rates.
        </p>
      </div>
    </div>
  </div>
</section>
