---
import Logo from './Logo.astro';
const year = new Date().getFullYear();
---

<footer class="border-t border-line bg-paper-100">
  <div class="mx-auto max-w-6xl px-5 py-12">
    <div class="flex flex-col gap-10 md:flex-row md:justify-between">
      <div class="max-w-sm">
        <Logo height={28} />
        <p class="mt-2 text-xs font-medium tracking-wider text-[#78716C]">STUDY SMART · VERIFIED FACTS</p>
        <p class="mt-3 text-sm leading-relaxed text-muted-500">
          The verified, distraction-free study OS for Indian students.
          Class 5 to UPSC. AI-powered. Free forever.
        </p>
      </div>

      <div class="grid grid-cols-2 gap-10 sm:grid-cols-3">
        <div>
          <h3 class="text-xs font-semibold uppercase tracking-[0.18em] text-ink-800">Product</h3>
          <ul class="mt-4 space-y-2.5 text-sm text-muted-500">
            <li><a href="/#why" class="hover:text-ink-900">Why Nexigrate</a></li>
            <li><a href="/#exams" class="hover:text-ink-900">Exams</a></li>
            <li><a href="/#how" class="hover:text-ink-900">How it works</a></li>
            <li><a href="/#credits" class="hover:text-ink-900">Credits</a></li>
            <li><a href="/pricing" class="hover:text-ink-900">Pricing</a></li>
          </ul>
        </div>

        <div>
          <h3 class="text-xs font-semibold uppercase tracking-[0.18em] text-ink-800">Company</h3>
          <ul class="mt-4 space-y-2.5 text-sm text-muted-500">
            <li><a href="mailto:hello@nexigrate.com" class="hover:text-ink-900">Contact</a></li>
            <li><a href="/#faq" class="hover:text-ink-900">FAQ</a></li>
            <li><a href="https://app.nexigrate.com" class="hover:text-ink-900">Sign in</a></li>
          </ul>
        </div>

        <div>
          <h3 class="text-xs font-semibold uppercase tracking-[0.18em] text-ink-800">Legal</h3>
          <ul class="mt-4 space-y-2.5 text-sm text-muted-500">
            <li><a href="/privacy" class="hover:text-ink-900">Privacy</a></li>
            <li><a href="/terms" class="hover:text-ink-900">Terms</a></li>
            <li><a href="/refund" class="hover:text-ink-900">Refunds</a></li>
          </ul>
        </div>
      </div>
    </div>

    <div class="divider-rule mt-10"></div>

    <div class="mt-6 flex flex-col items-start justify-between gap-3 text-xs text-muted-500 sm:flex-row sm:items-center">
      <p>© {year} Nexigrate. All rights reserved.</p>
      <p>Hosted in Mumbai, India · DPDP-aware by design.</p>
    </div>
  </div>
</footer>
