---
---

<section id="waitlist" class="section relative overflow-hidden">
  <div class="mx-auto max-w-6xl px-5 pt-14 pb-20 sm:pt-20 sm:pb-28 lg:pt-24">
    <div class="grid items-center gap-12 lg:grid-cols-12">
      <div class="lg:col-span-7">
        <p class="pill mb-6">
          <span class="inline-block h-1.5 w-1.5 rounded-full bg-ember-600"></span>
          Live · Class 5 to UPSC · AI-powered
        </p>

        <h1 class="font-serif text-3xl sm:text-5xl leading-[1.05] font-semibold tracking-tight text-ink-900 lg:text-7xl">
          Study smart.<br />
          Verified facts.<br />
          <span class="text-ember-600 italic">Zero distractions.</span>
        </h1>

        <p class="mt-7 max-w-xl text-lg leading-relaxed text-ink-800">
          The free study OS for Indian students. Class 5 to UPSC. Powered by AI,
          verified by experts, grounded in NCERT and official Government of India
          sources. Built to be calm.
        </p>

        <!-- Direct CTA instead of waitlist -->
        <div class="mt-8 flex flex-col gap-4 sm:flex-row sm:items-center">
          <a href="https://app.nexigrate.com/signin" class="btn-primary w-full sm:w-auto text-center text-lg px-8 py-3.5 shadow-lg hover:shadow-xl transition-shadow">
            Start free →
          </a>
          <p class="text-sm text-muted-500">No credit card. No ads. Ever.</p>
        </div>

        <!-- Stats -->
        <div class="mt-8 grid grid-cols-4 gap-4 max-w-lg">
          <div>
            <p class="font-serif text-2xl font-bold text-ink-900">63+</p>
            <p class="text-xs text-muted-500">Exams covered</p>
          </div>
          <div>
            <p class="font-serif text-2xl font-bold text-ink-900">3× AI</p>
            <p class="text-xs text-muted-500">Models</p>
          </div>
          <div>
            <p class="font-serif text-2xl font-bold text-ink-900">19+</p>
            <p class="text-xs text-muted-500">News sources</p>
          </div>
          <div>
            <p class="font-serif text-2xl font-bold text-ink-900">4hr</p>
            <p class="text-xs text-muted-500">Updates</p>
          </div>
        </div>

        <ul class="mt-7 flex flex-wrap gap-x-6 gap-y-2 text-sm text-muted-500">
          <li class="flex items-center gap-2">
            <svg class="h-4 w-4 text-ember-600" viewBox="0 0 20 20" fill="currentColor" aria-hidden="true">
              <path fill-rule="evenodd" d="M16.7 5.7a1 1 0 0 1 0 1.4l-7 7a1 1 0 0 1-1.4 0l-3.3-3.3a1 1 0 1 1 1.4-1.4L9 12l6.3-6.3a1 1 0 0 1 1.4 0Z" clip-rule="evenodd"/>
            </svg>
            Free forever
          </li>
          <li class="flex items-center gap-2">
            <svg class="h-4 w-4 text-ember-600" viewBox="0 0 20 20" fill="currentColor" aria-hidden="true">
              <path fill-rule="evenodd" d="M16.7 5.7a1 1 0 0 1 0 1.4l-7 7a1 1 0 0 1-1.4 0l-3.3-3.3a1 1 0 1 1 1.4-1.4L9 12l6.3-6.3a1 1 0 0 1 1.4 0Z" clip-rule="evenodd"/>
            </svg>
            Earn-as-you-learn credits
          </li>
          <li class="flex items-center gap-2">
            <svg class="h-4 w-4 text-ember-600" viewBox="0 0 20 20" fill="currentColor" aria-hidden="true">
              <path fill-rule="evenodd" d="M16.7 5.7a1 1 0 0 1 0 1.4l-7 7a1 1 0 0 1-1.4 0l-3.3-3.3a1 1 0 1 1 1.4-1.4L9 12l6.3-6.3a1 1 0 0 1 1.4 0Z" clip-rule="evenodd"/>
            </svg>
            No ads. No spam. Ever.
          </li>
        </ul>
      </div>

      {/* Hero illustration: a stylized open book on a study desk, all CSS/SVG. */}
      <div class="relative lg:col-span-5">
        <div class="paper-card relative aspect-[4/5] overflow-hidden p-6 sm:p-8">
          <div class="absolute inset-0 bg-gradient-to-br from-paper-200 to-paper-300"></div>

          {/* Open book */}
          <svg
            class="relative mx-auto h-full w-full"
            viewBox="0 0 320 400"
            fill="none"
            xmlns="http://www.w3.org/2000/svg"
            aria-hidden="true"
          >
            {/* Pages */}
            <path d="M40 80c0-4 3-8 7-8h106c4 0 7 4 7 8v240c0 4-3 8-7 8H47c-4 0-7-4-7-8V80Z" fill="#FBF6E8" stroke="#D9CDB0" stroke-width="1.5"/>
            <path d="M160 80c0-4 3-8 7-8h106c4 0 7 4 7 8v240c0 4-3 8-7 8H167c-4 0-7-4-7-8V80Z" fill="#FBF6E8" stroke="#D9CDB0" stroke-width="1.5"/>
            <line x1="160" y1="72" x2="160" y2="328" stroke="#C7B98A" stroke-width="1.5" stroke-dasharray="2 4"/>

            {/* Lines of text on left page */}
            <line x1="55" y1="100" x2="145" y2="100" stroke="#2A241A" stroke-width="3" stroke-linecap="round"/>
            <line x1="55" y1="120" x2="135" y2="120" stroke="#2A241A" stroke-width="2" stroke-linecap="round" opacity="0.55"/>
            <line x1="55" y1="138" x2="145" y2="138" stroke="#2A241A" stroke-width="2" stroke-linecap="round" opacity="0.55"/>
            <line x1="55" y1="156" x2="120" y2="156" stroke="#2A241A" stroke-width="2" stroke-linecap="round" opacity="0.55"/>
            <line x1="55" y1="184" x2="145" y2="184" stroke="#2A241A" stroke-width="2" stroke-linecap="round" opacity="0.55"/>
            <line x1="55" y1="202" x2="140" y2="202" stroke="#2A241A" stroke-width="2" stroke-linecap="round" opacity="0.55"/>
            <line x1="55" y1="220" x2="125" y2="220" stroke="#2A241A" stroke-width="2" stroke-linecap="round" opacity="0.55"/>
            <line x1="55" y1="248" x2="145" y2="248" stroke="#2A241A" stroke-width="2" stroke-linecap="round" opacity="0.55"/>
            <line x1="55" y1="266" x2="138" y2="266" stroke="#2A241A" stroke-width="2" stroke-linecap="round" opacity="0.55"/>

            {/* Right page: a "verified" stamp */}
            <circle cx="220" cy="160" r="38" stroke="#8B2E1A" stroke-width="2.5" opacity="0.85"/>
            <circle cx="220" cy="160" r="32" stroke="#8B2E1A" stroke-width="1" opacity="0.6"/>
            <text x="220" y="156" text-anchor="middle" font-family="Lora, serif" font-size="11" font-weight="700" fill="#8B2E1A" opacity="0.9">VERIFIED</text>
            <text x="220" y="172" text-anchor="middle" font-family="Lora, serif" font-size="9" fill="#8B2E1A" opacity="0.75">3 × AI + SME</text>

            {/* Lines on right page */}
            <line x1="175" y1="220" x2="265" y2="220" stroke="#2A241A" stroke-width="2" stroke-linecap="round" opacity="0.55"/>
            <line x1="175" y1="238" x2="255" y2="238" stroke="#2A241A" stroke-width="2" stroke-linecap="round" opacity="0.55"/>
            <line x1="175" y1="256" x2="262" y2="256" stroke="#2A241A" stroke-width="2" stroke-linecap="round" opacity="0.55"/>
            <line x1="175" y1="284" x2="265" y2="284" stroke="#2A241A" stroke-width="2" stroke-linecap="round" opacity="0.55"/>
            <line x1="175" y1="302" x2="245" y2="302" stroke="#2A241A" stroke-width="2" stroke-linecap="round" opacity="0.55"/>

            {/* Bookmark ribbon */}
            <path d="M232 72v52l-10-8-10 8V72h20Z" fill="#8B2E1A"/>
          </svg>
        </div>
      </div>
    </div>
  </div>
</section>
