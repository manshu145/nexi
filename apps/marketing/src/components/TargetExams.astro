---
import { LIVE_EXAMS } from '~/data/exams';
---

<section id="exams" class="section">
  <div class="mx-auto max-w-6xl px-5 py-20 sm:py-24">
    <div class="max-w-2xl">
      <p class="pill mb-5">Exams</p>
      <h2 class="font-serif text-3xl font-semibold leading-tight text-ink-900 sm:text-4xl">
        One platform. Every exam.
      </h2>
      <p class="mt-4 text-lg leading-relaxed text-ink-800">
        From Class 5 to UPSC, covering all major boards and competitive exams across India. 40+ exams live now.
      </p>
    </div>

    <div class="mt-12 flex flex-wrap gap-2.5">
      {LIVE_EXAMS.map((exam) => (
        <span class="pill cursor-default">
          <span class="inline-block h-1.5 w-1.5 rounded-full bg-ember-600"></span>
          {exam.name}
        </span>
      ))}
    </div>

    <p class="mt-10 max-w-3xl text-sm text-muted-500">
      Don't see your exam? Pick "Still deciding" on the waitlist form and we
      will prioritise the exams our earliest students actually need.
    </p>
  </div>
</section>
