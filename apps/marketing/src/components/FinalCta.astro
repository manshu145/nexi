---
import { EXAMS } from '~/data/exams';

const examCount = EXAMS.length;
---

<section class="border-t border-line bg-paper-50/70">
  <div class="mx-auto max-w-3xl px-5 py-20 text-center sm:py-24">
    <p class="pill mb-5">Live now</p>
    <h2 class="font-serif text-3xl font-semibold leading-tight text-ink-900 sm:text-5xl">
      Start studying today.
    </h2>
    <p class="mx-auto mt-4 max-w-xl text-lg leading-relaxed text-ink-800">
      {examCount}+ exams. AI-powered personalized learning. Hindi + English.
      Completely free to start. No credit card needed.
    </p>

    <div class="mt-8 flex flex-col gap-4 items-center">
      <a href="https://app.nexigrate.com/signin" class="btn-primary text-center text-lg px-10 py-4 shadow-lg hover:shadow-xl transition-shadow">
        Start free — it takes 30 seconds
      </a>
      <p class="text-sm text-muted-500">
        Already have an account? <a href="https://app.nexigrate.com/signin" class="underline hover:text-ink-900">Sign in</a>
      </p>
    </div>
  </div>
</section>
