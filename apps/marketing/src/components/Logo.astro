---
interface Props {
  class?: string;
  height?: number;
}
const { class: className = '', height = 36 } = Astro.props;
const width = height * 4;
---

<a href="/" class={`inline-flex items-center ${className}`} aria-label="Nexigrate home">
  <img
    src="/brand/nexigrate-logo-light.svg"
    alt="Nexigrate"
    width={width}
    height={height}
    style={`height: ${height}px; width: auto;`}
    class="block dark:hidden object-contain"
  />
  <img
    src="/brand/nexigrate-logo-dark.svg"
    alt="Nexigrate"
    width={width}
    height={height}
    style={`height: ${height}px; width: auto;`}
    class="hidden dark:block object-contain"
  />
</a>
